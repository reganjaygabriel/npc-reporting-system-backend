# NPC Live Data Configuration
# Copy this to .env and fill in the values provided by NPC

# NPC API Configuration
NPC_API_URL=https://api.napocor.gov.ph/v1
NPC_API_KEY=your_api_key_here
NPC_API_TIMEOUT=30

# NPC Authentication (if using username/password instead of API key)
NPC_USERNAME=your_username
NPC_PASSWORD=your_password

# Alternative: Database Connection (if NPC provides direct database access)
NPC_DB_HOST=npc-database.napocor.gov.ph
NPC_DB_PORT=5432
NPC_DB_NAME=npc_scada
NPC_DB_USER=your_db_username
NPC_DB_PASSWORD=your_db_password

# Data Sync Settings
NPC_SYNC_INTERVAL=300  # Sync every 5 minutes (in seconds)
NPC_AUTO_SYNC=False    # Enable automatic syncing
